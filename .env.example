# ClawOps environment variables
# Copy to .env and fill in your values

# OpenClaw Gateway (set during openclaw onboard)
OPENCLAW_API_KEY=your_openclaw_api_key_here
OPENCLAW_GATEWAY_URL=http://localhost:59000

# Optional: real CI/CD integrations
GITHUB_TOKEN=ghp_your_token_here
GITHUB_ORG=your-org

# Optional: Kubernetes (for real deployments)
KUBECONFIG=/path/to/kubeconfig

# Optional: Slack alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# NemoClaw sandbox (auto-set by nemoclaw installer)
NEMOCLAW_SANDBOX_HOST=localhost
NEMOCLAW_SANDBOX_PORT=8080
